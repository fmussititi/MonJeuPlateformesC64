                "-f=${workspaceFolder}\\assets\\colour1.bin",
                "-f=${workspaceFolder}\\assets\\tiles1.bin",

                "-fz=${workspaceFolder}\\assets\\chars2.bin",
                "-fz=${workspaceFolder}\\assets\\map2.bin",
                "-f=${workspaceFolder}\\assets\\colour2.bin",
                "-f=${workspaceFolder}\\assets\\tiles2.bin",
                
                "-fz=${workspaceFolder}\\assets\\chars3.bin",
                "-fz=${workspaceFolder}\\assets\\map3.bin",
                "-f=${workspaceFolder}\\assets\\colour3.bin",
                "-f=${workspaceFolder}\\assets\\tiles3.bin"
