{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "build oscar64",
            "command": "F:\\CompilationC64\\oscar64\\bin\\oscar64.exe",
            "args": [
                "-O1",
                "${workspaceFolder}\\SpaceTaxi.c",
                "-d64=${workspaceFolder}\\SpaceTaxi.d64"
